    <!-- Anti-empty-jar safety net (see jar-must-not-be-empty in build/plugins).
         Default: skipped everywhere. Jar-packaged modules that suffered from
         empty-jar corruption (garganttua-workflow as of 2026-05-29) opt-IN by
         overriding this to false. Pom / maven-plugin modules just inherit the
         default and the rule is a no-op for them. -->
    <enforce.jar.size.skip>true</enforce.jar.size.skip>

    <!-- Direct Binder Generation: AOT descriptors are produced consumer-side
         (the framework can't generate descriptors for its own infrastructure
         types because the resulting AOTClass_* sources depend on
         garganttua-aot-commons which itself depends on garganttua-commons —
         circular). Leave false in the framework build; downstream apps that
         want AOT mode flip this in their own build alongside the
         garganttua-aot-maven-plugin. -->
    <garganttua.direct.binders>false</garganttua.direct.binders>
