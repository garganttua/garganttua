  <build>
    <plugins>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-compiler-plugin</artifactId>
        <version>${maven.compiler.plugin.version}</version>
        <configuration>
          <compilerArgs>
            <arg>-parameters</arg>
            <arg>-Agarganttua.direct.binders=${garganttua.direct.binders}</arg>
          </compilerArgs>
          <release>${java.version}</release>
          <annotationProcessorPaths>
            <path>
              <groupId>com.garganttua.core</groupId>
              <artifactId>garganttua-aot-annotation-processor</artifactId>
              <version>${project.version}</version>
            </path>
          </annotationProcessorPaths>
        </configuration>
      </plugin>
      <plugin>
        <artifactId>maven-surefire-plugin</artifactId>
        <version>${maven.surefire.plugin.version}</version>
      </plugin>
      <!-- Inject coordinates into every JAR's MANIFEST.MF so the
           Bootstrap module can discover which garganttua-* modules are on
           the classpath and print their versions in the post-build
           summary. Discovery: GarganttuaModules.discover() walks
           ClassLoader.getResources("META-INF/MANIFEST.MF") and filters
           Implementation-Vendor starting with "com.garganttua". -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-jar-plugin</artifactId>
        <configuration>
          <archive>
            <manifestEntries>
              <Implementation-Title>${project.name}</Implementation-Title>
              <Implementation-Version>${project.version}</Implementation-Version>
              <Implementation-Vendor>${project.groupId}</Implementation-Vendor>
              <Garganttua-Module>${project.artifactId}</Garganttua-Module>
            </manifestEntries>
          </archive>
        </configuration>
      </plugin>
      <plugin>
        <groupId>org.jacoco</groupId>
        <artifactId>jacoco-maven-plugin</artifactId>
        <version>${jacoco.maven.plugin.version}</version>
        <executions>
          <execution>
            <goals>
              <goal>prepare-agent</goal>
            </goals>
          </execution>
          <execution>
            <id>report</id>
            <phase>test</phase>
            <goals>
              <goal>report</goal>
            </goals>
          </execution>
        </executions>
      </plugin>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-source-plugin</artifactId>
        <version>${maven.source.plugin.version}</version>
        <executions>
          <execution>
            <id>attach-sources</id>
            <goals>
              <goal>jar</goal>
            </goals>
          </execution>
        </executions>
      </plugin>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-javadoc-plugin</artifactId>
        <version>${maven.javadoc.plugin.version}</version>
        <configuration>
          <source>${java.version}</source>
          <failOnError>false</failOnError>
          <doclint>none</doclint>
        </configuration>
        <executions>
          <execution>
            <id>attach-javadocs</id>
            <phase>package</phase>
            <goals>
              <goal>jar</goal>
            </goals>
          </execution>
        </executions>
      </plugin>
      <!-- Verify the jar produced is not the 3 KB stub (only META-INF +
           directory entries, no .class files) before install can copy it
           into ~/.m2. Triggered by an IDE-driven or watcher-triggered
           partial build that bypasses compile and leaves us with an empty
           jar — corrupts every downstream consumer until reinstalled.
           Skips POM-packaged modules and the test-resource regeneration. -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-enforcer-plugin</artifactId>
        <version>3.5.0</version>
        <executions>
          <execution>
            <id>jar-must-not-be-empty</id>
            <phase>verify</phase>
            <goals><goal>enforce</goal></goals>
            <configuration>
              <skip>${enforce.jar.size.skip}</skip>
              <rules>
                <requireFilesSize>
                  <message>JAR ${project.build.finalName}.jar is suspiciously small (&lt; 5 KB). Refusing to install — likely a build that skipped compile. Check IDE Maven settings / file watchers.</message>
                  <files>
                    <file>${project.build.directory}/${project.build.finalName}.jar</file>
                  </files>
                  <minsize>5000</minsize>
                  <!-- maxsize defaults to 10000 — override to "no upper bound"
                       (any positive value the rule will accept). -->
                  <maxsize>2147483647</maxsize>
                </requireFilesSize>
              </rules>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
