<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>com.garganttua.core</groupId>
        <artifactId>garganttua-aot</artifactId>
        <version>3.0.0-ALPHA04</version>
    </parent>
    <artifactId>garganttua-aot-annotation-processor</artifactId>
    <packaging>jar</packaging>
    <description>Compile-time annotation processor for generating AOT class descriptors.</description>

    <dependencies>
        <dependency>
            <groupId>com.garganttua.core</groupId>
            <artifactId>garganttua-commons</artifactId>
        </dependency>
        <!-- Test scope: the real @Observer annotation, to run the
             IndexedAnnotationProcessor against it in an end-to-end test
             that reproduces the user-reported failure. -->
        <dependency>
            <groupId>com.garganttua.core</groupId>
            <artifactId>garganttua-observability</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter-engine</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>${maven.compiler.plugin.version}</version>
                <configuration>
                    <compilerArgs>
                        <arg>-parameters</arg>
                        <!-- Disable annotation processing for this module to avoid self-processing -->
                        <arg>-proc:none</arg>
                    </compilerArgs>
                    <release>${java.version}</release>
                    <!-- Override parent: this module has no annotation processors. -->
                    <annotationProcessorPaths combine.self="override"/>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>
