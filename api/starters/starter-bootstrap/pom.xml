<project xmlns="http://maven.apache.org/POM/4.0.0"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>
	<parent>
		<groupId>com.garganttua</groupId>
		<artifactId>garganttua-api-starters</artifactId>
		<version>3.0.0-ALPHA04</version>
	</parent>
	<artifactId>garganttua-api-starter-bootstrap</artifactId>
	<packaging>jar</packaging>
	<description>Bootstrap starter: a Spring-Boot-style runner (GarganttuaApplication.run) that
		assembles the framework, scans @Entity/@Dto, runs ServiceLoader auto-configs and reads
		application.yaml — transport- and persistence-agnostic (no Mongo, no Javalin).</description>

	<!--
	  garganttua-api-starter-bootstrap — the SOCLE. It carries the Java that
	  turns the framework into a one-call boot experience:

	    * GarganttuaApplication.run(App.class, args)  — drives core's Bootstrap
	      (which installs IReflection + auto-wires the injection/expression/
	      runtimes/scripts/workflows builders via ServiceLoader), then onInit/
	      onStart.
	    * GarganttuaConfig — reads application.yaml / application.properties +
	      environment-variable overrides (implements commons' IConfig).
	    * Discovers IApiAutoConfiguration services and applies them before build.

	  It brings the framework only — it is reflection-provider-agnostic and does
	  NOT choose a reflection stack. The aggregators do: the JVM aggregator adds
	  the runtime reflection providers, the AOT aggregator adds the AOT ones.
	  Persistence (mongodb) and transport (javalin) are likewise separate add-on
	  starters that auto-wire themselves when present. The runner is unchanged
	  regardless of which providers sit on the classpath.
	-->

	<dependencies>
		<dependency>
			<groupId>com.garganttua</groupId>
			<artifactId>garganttua-api-core</artifactId>
		</dependency>

		<!-- No reflection provider here: this socle stays provider-agnostic.
		     The runtime stack is brought by garganttua-api-starter-jvm-*, the
		     AOT stack by garganttua-api-starter-aot-*. -->

		<!-- Bootstrap orchestrator (Bootstrap.builder() cold-start + SPI wiring). -->
		<dependency>
			<groupId>com.garganttua.core</groupId>
			<artifactId>garganttua-bootstrap</artifactId>
		</dependency>

		<!-- application.yaml parser — single jar, no transitive deps. -->
		<dependency>
			<groupId>org.yaml</groupId>
			<artifactId>snakeyaml</artifactId>
		</dependency>

		<!-- Test stack. -->
		<dependency>
			<groupId>org.junit.jupiter</groupId>
			<artifactId>junit-jupiter-engine</artifactId>
			<scope>test</scope>
		</dependency>
		<dependency>
			<groupId>org.mockito</groupId>
			<artifactId>mockito-core</artifactId>
			<scope>test</scope>
		</dependency>
		<dependency>
			<groupId>org.mockito</groupId>
			<artifactId>mockito-junit-jupiter</artifactId>
			<scope>test</scope>
		</dependency>
	</dependencies>

	<!-- The shared config/checkstyle/checkstyle.xml SuppressionFilter reads
	     ${checkstyle.suppressions.file}; the plugin only populates that property from
	     suppressionsLocation. The api parent omits it, so checkstyle:check cannot parse
	     its config. Point it at the existing shared suppressions file (no edit to config/). -->
	<build>
		<plugins>
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-checkstyle-plugin</artifactId>
				<version>3.6.0</version>
				<configuration>
					<suppressionsLocation>${maven.multiModuleProjectDirectory}/config/checkstyle/suppressions.xml</suppressionsLocation>
				</configuration>
			</plugin>
		</plugins>
	</build>
</project>
