<project xmlns="http://maven.apache.org/POM/4.0.0"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>
	<parent>
		<groupId>com.garganttua</groupId>
		<artifactId>garganttua-api</artifactId>
		<version>3.0.0-ALPHA05</version>
	</parent>
	<artifactId>garganttua-api-starters</artifactId>
	<packaging>pom</packaging>
	<description>Opinionated Spring Boot / Javalin starters bundling a ready-to-run API stack (parent module).</description>

	<!--
	  Starter modules are pure aggregator poms: each one declares the set of
	  modules + core dependencies you need for a given stack (reflection
	  strategy, persistence, transport). They never ship Java code, so the
	  framework keeps the "let the user choose" property — the starter just
	  spares you from typing the same five <dependency> blocks every project.

	  Consuming a starter:

	      <dependency>
	          <groupId>com.garganttua</groupId>
	          <artifactId>garganttua-api-starter-jvm-mongo-javalin</artifactId>
	          <version>3.0.0-ALPHA05</version>
	      </dependency>
	-->

	<modules>
		<!-- Code-bearing starters: the bootstrap runner + auto-config add-ons. -->
		<module>starter-bootstrap</module>
		<module>starter-mongodb</module>
		<module>starter-javalin</module>
		<!-- Aggregators: compose the above into ready-to-use stacks. -->
		<module>starter-quickstart</module>
		<module>starter-jvm-mongo-javalin</module>
		<module>starter-aot-mongo-javalin</module>
	</modules>
</project>
