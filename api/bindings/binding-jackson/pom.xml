<project xmlns="http://maven.apache.org/POM/4.0.0"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>
	<parent>
		<groupId>com.garganttua</groupId>
		<artifactId>garganttua-api-bindings</artifactId>
		<version>3.0.0-ALPHA05</version>
	</parent>
	<artifactId>garganttua-api-binding-jackson</artifactId>

	<description>Binding wrapping Jackson (annotations, core, databind, dataformat-xml + geojson-jackson) — pins the JSON/XML (de)serialization library used across the API and ships the framework's JSON and XML ISerializer implementations.</description>

	<dependencies>
		<dependency>
			<groupId>com.fasterxml.jackson.core</groupId>
			<artifactId>jackson-annotations</artifactId>
			<version>${jackson.version}</version>
		</dependency>
		<dependency>
			<groupId>com.fasterxml.jackson.core</groupId>
			<artifactId>jackson-core</artifactId>
			<version>${jackson.version}</version>
		</dependency>
		<dependency>
			<groupId>com.fasterxml.jackson.core</groupId>
			<artifactId>jackson-databind</artifactId>
			<version>${jackson.version}</version>
		</dependency>
		<dependency>
			<groupId>de.grundid.opendatalab</groupId>
			<artifactId>geojson-jackson</artifactId>
			<version>${geojson-jackson.version}</version>
			<exclusions>
				<exclusion>
					<groupId>com.fasterxml.jackson.core</groupId>
					<artifactId>jackson-core</artifactId>
				</exclusion>
				<exclusion>
					<groupId>com.fasterxml.jackson.core</groupId>
					<artifactId>jackson-annotations</artifactId>
				</exclusion>
				<exclusion>
					<groupId>com.fasterxml.jackson.core</groupId>
					<artifactId>jackson-databind</artifactId>
				</exclusion>
			</exclusions>
		</dependency>

		<!-- XML (de)serialization — Jackson's XmlMapper sits beside the JSON ObjectMapper. -->
		<dependency>
			<groupId>com.fasterxml.jackson.dataformat</groupId>
			<artifactId>jackson-dataformat-xml</artifactId>
			<version>${jackson.version}</version>
		</dependency>

		<!-- Java 8 date/time (java.time.Instant, LocalDate*, …) — without this module
		     Jackson throws on any non-null temporal field. Registered on every mapper
		     by AbstractJacksonSerializer so JSON and XML both render ISO-8601. -->
		<dependency>
			<groupId>com.fasterxml.jackson.datatype</groupId>
			<artifactId>jackson-datatype-jsr310</artifactId>
			<version>${jackson.version}</version>
		</dependency>

		<!-- Contract layer: ISerializer, MimeType, @Serializer, ApiException, IClass. -->
		<dependency>
			<groupId>com.garganttua</groupId>
			<artifactId>garganttua-api-commons</artifactId>
		</dependency>

		<!-- test: garganttua-core's Bootstrap cold-starts an IReflection so
		     IClass.getClass(...) resolves. NOT garganttua-api-core — core depends on
		     this binding, which would close a reactor cycle. -->
		<dependency>
			<groupId>com.garganttua.core</groupId>
			<artifactId>garganttua-bootstrap</artifactId>
			<version>${garganttua.core.version}</version>
			<scope>test</scope>
		</dependency>
		<dependency>
			<groupId>org.junit.jupiter</groupId>
			<artifactId>junit-jupiter-engine</artifactId>
			<scope>test</scope>
		</dependency>
	</dependencies>

	<!-- The shared config/checkstyle/checkstyle.xml SuppressionFilter reads
	     ${checkstyle.suppressions.file}; the plugin only populates that property from
	     suppressionsLocation. The api parent omits it, so checkstyle:check cannot parse
	     its config. Point it at the existing shared suppressions file (no edit to config/).
	     Scoped to the quality profile (which also supplies the plugin version) so the
	     default offline test build is untouched. -->
	<profiles>
		<profile>
			<id>quality</id>
			<build>
				<plugins>
					<plugin>
						<groupId>org.apache.maven.plugins</groupId>
						<artifactId>maven-checkstyle-plugin</artifactId>
						<configuration>
							<configLocation>${maven.multiModuleProjectDirectory}/config/checkstyle/checkstyle.xml</configLocation>
							<suppressionsLocation>${maven.multiModuleProjectDirectory}/config/checkstyle/suppressions.xml</suppressionsLocation>
							<includeTestSourceDirectory>false</includeTestSourceDirectory>
							<failOnViolation>true</failOnViolation>
							<violationSeverity>warning</violationSeverity>
							<consoleOutput>true</consoleOutput>
						</configuration>
					</plugin>
				</plugins>
			</build>
		</profile>
	</profiles>
</project>
