				<artifactId>garganttua-aot-commons</artifactId>
				<version>${garganttua.core.version}</version>
			</dependency>
			<dependency>
				<groupId>com.garganttua.core</groupId>
				<artifactId>garganttua-aot-reflection</artifactId>
				<version>${garganttua.core.version}</version>
			</dependency>
			<dependency>
				<groupId>com.garganttua.core</groupId>
				<artifactId>garganttua-aot-annotation-scanner</artifactId>
				<version>${garganttua.core.version}</version>
			</dependency>
			<dependency>
				<groupId>com.garganttua.core</groupId>
				<artifactId>garganttua-crypto</artifactId>
				<version>${garganttua.core.version}</version>
			</dependency>

			<!-- Garganttua API bindings — each wraps one external lib. -->
			<dependency>
				<groupId>com.garganttua</groupId>
				<artifactId>garganttua-api-binding-jackson</artifactId>
				<version>${project.version}</version>
			</dependency>
			<dependency>
				<groupId>com.garganttua</groupId>
				<artifactId>garganttua-api-binding-slf4j</artifactId>
				<version>${project.version}</version>
			</dependency>
			<dependency>
				<groupId>com.garganttua</groupId>
				<artifactId>garganttua-api-binding-jsonpath</artifactId>
				<version>${project.version}</version>
			</dependency>
			<dependency>
				<groupId>com.garganttua</groupId>
				<artifactId>garganttua-api-binding-mongodb</artifactId>
				<version>${project.version}</version>
			</dependency>
			<dependency>
				<groupId>com.garganttua</groupId>
				<artifactId>garganttua-api-binding-javalin</artifactId>
				<version>${project.version}</version>
			</dependency>

			<!-- Standalone third-party deps reintroduced directly (kept
			     outside bindings on user's instruction). -->
			<dependency>
				<groupId>org.javatuples</groupId>
				<artifactId>javatuples</artifactId>
				<version>${javatuples.version}</version>
			</dependency>
			<dependency>
				<groupId>jakarta.inject</groupId>
				<artifactId>jakarta.inject-api</artifactId>
				<version>${jakarta-inject.version}</version>
			</dependency>
			<dependency>
				<groupId>org.yaml</groupId>
				<artifactId>snakeyaml</artifactId>
				<version>${snakeyaml.version}</version>
			</dependency>
			<dependency>
				<groupId>org.junit.jupiter</groupId>
				<artifactId>junit-jupiter-engine</artifactId>
				<version>${junit.version}</version>
				<scope>test</scope>
			</dependency>
			<dependency>
				<groupId>org.mockito</groupId>
				<artifactId>mockito-core</artifactId>
				<version>${mockito.version}</version>
				<scope>test</scope>
			</dependency>
			<dependency>
				<groupId>org.mockito</groupId>
				<artifactId>mockito-junit-jupiter</artifactId>
				<version>${mockito.version}</version>
				<scope>test</scope>
			</dependency>

			<!-- Third-party dependencies intentionally absent.
			     The api restricts itself to the garganttua ecosystem
			     (com.garganttua / com.garganttua.core). Every external
			     binding — lombok, slf4j-*, jackson-*, json-path,
			     javatuples, reflections, geojson, javax.inject, junit,
			     mockito, etc. — is delegated to dedicated binding
			     sub-modules to be introduced later. Until those bindings
			     land, downstream consumers must declare third-party deps
			     themselves. -->
		</dependencies>
	</dependencyManagement>

	<build>
		<pluginManagement>
			<plugins>
				<plugin>
					<groupId>org.apache.maven.plugins</groupId>
					<artifactId>maven-compiler-plugin</artifactId>
					<version>${maven-compiler-plugin.version}</version>
					<configuration>
						<source>${java.version}</source>
						<target>${java.version}</target>
						<compilerArgs>
							<arg>-parameters</arg>
							<!-- Level 2 AOT: instructs garganttua-aot-annotation-processor's
								 DirectBinderGenerator to emit AOTClass_*/AOTField_*/AOTMethod_*
								 source files for every @Reflected type, registered into
								 AOTRegistry via static initialisers. Pairs with the
								 Level 1 @Indexed APT below — both processors live in the
								 same jar, but DirectBinderGenerator is gated by this
								 option whereas IndexedAnnotationProcessor always runs. -->
							<arg>-Agarganttua.direct.binders=true</arg>
						</compilerArgs>
						<annotationProcessorPaths>
							<!-- Lombok APT path removed alongside the rest of the
							     third-party purge — to be reintroduced as part of a
							     lombok binding sub-module. -->

							<!-- Level 1: @Indexed annotation index generation.
								 Level 2: @Reflected direct binder generation
								 (gated by -Agarganttua.direct.binders=true above). -->
							<path>
								<groupId>com.garganttua.core</groupId>
								<artifactId>garganttua-aot-annotation-processor</artifactId>
								<version>${garganttua.core.version}</version>
							</path>
						</annotationProcessorPaths>
					</configuration>
				</plugin>
				<plugin>
					<artifactId>maven-surefire-plugin</artifactId>
					<version>${maven-surefire-plugin.version}</version>
					<configuration>
						<!-- Mockito's ByteBuddy doesn't yet officially recognise the
						     Java 25 (class file v69) runtime the project now builds on;
						     enable ByteBuddy's experimental mode so mock generation works.
						     NOTE: Mockito 5.14.2 / ByteBuddy still flake intermittently on
						     full runs under JDK 25 (inline mock-maker self-attach). Durable
						     fix = bump Mockito + ByteBuddy to JDK-25-native versions (needs
						     online resolution); then this flag can be dropped. -->
						<!-- @{argLine} is the late-bound property JaCoCo's prepare-agent
						     sets; prepend it so the coverage agent loads alongside the
						     ByteBuddy flag (without it our literal argLine would clobber
						     JaCoCo and every report would read 0%). -->
						<argLine>@{argLine} -Dnet.bytebuddy.experimental=true</argLine>
					</configuration>
				</plugin>
				<plugin>
					<groupId>org.apache.maven.plugins</groupId>
					<artifactId>maven-source-plugin</artifactId>
					<version>${maven-source-plugin.version}</version>
				</plugin>
			</plugins>
		</pluginManagement>
		<plugins>
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-compiler-plugin</artifactId>
			</plugin>
			<plugin>
				<artifactId>maven-surefire-plugin</artifactId>
			</plugin>
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-source-plugin</artifactId>
				<executions>
					<execution>
						<id>attach-sources</id>
						<goals>
							<goal>jar</goal>
						</goals>
					</execution>
				</executions>
			</plugin>
			<!-- Attach a -javadoc.jar to every module (parity with garganttua-core).
			     doclint=none + failOnError=false: partial javadoc never fails the
			     release build; the jar ships whatever exists. -->
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-javadoc-plugin</artifactId>
				<version>${maven-javadoc-plugin.version}</version>
				<configuration>
					<source>${java.version}</source>
					<failOnError>false</failOnError>
					<doclint>none</doclint>
				</configuration>
				<executions>
					<execution>
						<id>attach-javadocs</id>
						<phase>package</phase>
						<goals>
							<goal>jar</goal>
						</goals>
					</execution>
				</executions>
			</plugin>
			<!-- Code coverage (parity with garganttua-core). prepare-agent before
			     tests, report bound to the test phase → target/site/jacoco/ per module. -->
			<plugin>
				<groupId>org.jacoco</groupId>
				<artifactId>jacoco-maven-plugin</artifactId>
				<version>${jacoco-maven-plugin.version}</version>
				<executions>
					<execution>
						<goals>
							<goal>prepare-agent</goal>
						</goals>
					</execution>
					<execution>
						<id>report</id>
						<phase>test</phase>
						<goals>
							<goal>report</goal>
						</goals>
					</execution>
				</executions>
			</plugin>
			<!-- Stamp each jar's MANIFEST.MF so the module self-identifies at runtime
			     (parity with core; Implementation-Vendor=com.garganttua lets a module
			     scan discover the framework jars on the classpath). -->
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-jar-plugin</artifactId>
				<version>${maven-jar-plugin.version}</version>
				<configuration>
					<archive>
						<manifestEntries>
							<Implementation-Title>${project.name}</Implementation-Title>
							<Implementation-Version>${project.version}</Implementation-Version>
							<Implementation-Vendor>${project.groupId}</Implementation-Vendor>
							<Garganttua-Module>${project.artifactId}</Garganttua-Module>
						</manifestEntries>
					</archive>
				</configuration>
			</plugin>
			<!-- Refuse to install a stub jar (only META-INF, no .class) — the empty
			     jar an IDE-driven partial build can leave behind, which corrupts every
			     downstream consumer. Dormant by default (enforce.jar.size.skip=true),
			     opt-in per jar-packaged module. Mirrors core. -->
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-enforcer-plugin</artifactId>
				<version>${maven-enforcer-plugin.version}</version>
				<executions>
					<execution>
						<id>jar-must-not-be-empty</id>
						<phase>verify</phase>
						<goals><goal>enforce</goal></goals>
						<configuration>
							<skip>${enforce.jar.size.skip}</skip>
							<rules>
								<requireFilesSize>
									<message>JAR ${project.build.finalName}.jar is suspiciously small (&lt; 5 KB). Refusing to install — likely a build that skipped compile. Check IDE Maven settings / file watchers.</message>
									<files>
										<file>${project.build.directory}/${project.build.finalName}.jar</file>
									</files>
									<minsize>5000</minsize>
									<maxsize>2147483647</maxsize>
								</requireFilesSize>
							</rules>
						</configuration>
					</execution>
				</executions>
			</plugin>
		</plugins>
	</build>

	<modules>
		<module>bindings</module>
		<module>commons</module>
		<module>core</module>
		<module>dao</module>
		<module>starters</module>
