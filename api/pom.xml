			</dependency>
			<dependency>
				<groupId>com.garganttua.core</groupId>
				<artifactId>garganttua-injection</artifactId>
				<version>${garganttua.core.version}</version>
			</dependency>
			<dependency>
				<groupId>com.garganttua.core</groupId>
				<artifactId>garganttua-mapper</artifactId>
				<version>${garganttua.core.version}</version>
			</dependency>
			<dependency>
				<groupId>com.garganttua.core</groupId>
				<artifactId>garganttua-native</artifactId>
				<version>${garganttua.core.version}</version>
			</dependency>
			<dependency>
				<groupId>com.garganttua.core</groupId>
				<artifactId>garganttua-commons</artifactId>
				<version>${garganttua.core.version}</version>
			</dependency>
			<dependency>
				<groupId>com.garganttua.core</groupId>
				<artifactId>garganttua-observability</artifactId>
