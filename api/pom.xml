<project xmlns="http://maven.apache.org/POM/4.0.0"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>
	<groupId>com.garganttua</groupId>
	<artifactId>garganttua-api</artifactId>
	<packaging>pom</packaging>
	<description>Declarative, annotation-driven REST API framework — multi-tenancy, pluggable security, AOT/native-ready — built on garganttua-core.</description>
	<version>3.0.0-ALPHA05</version>

	<licenses>
		<license>
			<name>MIT License</name>
			<url>https://opensource.org/licenses/MIT</url>
		</license>
	</licenses>

	<developers>
		<developer>
			<name>Jérémy Colombet</name>
			<email>jeremy.colombet@garganttua.com</email>
		</developer>
	</developers>

	<repositories>
		<repository>
			<id>github garganttua core</id>
			<name>github garganttua core</name>
			<url>https://maven.pkg.github.com/garganttua/garganttua-core</url>
		</repository>
	</repositories>

	<distributionManagement>
		<snapshotRepository>
			<id>github garganttua api</id>
			<name>github garganttua api</name>
			<url>https://maven.pkg.github.com/garganttua/garganttua-api</url>
		</snapshotRepository>
		<repository>
			<id>github garganttua api</id>
			<name>github garganttua api</name>
			<url>https://maven.pkg.github.com/garganttua/garganttua-api</url>
		</repository>
	</distributionManagement>

	<properties>
		<!-- Encoding -->
		<project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
		<java.version>25</java.version>

		<!-- Garganttua Core -->
		<garganttua.core.version>3.0.0-ALPHA05</garganttua.core.version>

		<!-- Binding library versions — each binding sub-module wraps
		     ONE external library, and these properties pin its version
		     here so a single edit propagates everywhere. -->
		<jackson.version>2.18.6</jackson.version>
		<geojson-jackson.version>1.14</geojson-jackson.version>
		<slf4j.version>2.0.13</slf4j.version>
		<json-path.version>2.9.0</json-path.version>
		<mongodb-driver.version>5.1.1</mongodb-driver.version>
		<javalin.version>6.6.0</javalin.version>

		<!-- Standalone deps reintroduced directly (no binding wrapper). -->
		<javatuples.version>1.2</javatuples.version>
		<jakarta-inject.version>2.0.1</jakarta-inject.version>
		<!-- YAML parser for the bootstrap starter's application.yaml loader.
		     Single jar, zero transitive deps — keeps the bootstrap core free
		     of jackson/databind. -->
		<snakeyaml.version>2.3</snakeyaml.version>
		<junit.version>5.11.4</junit.version>
		<mockito.version>5.14.2</mockito.version>

		<!-- Plugin versions -->
		<maven-compiler-plugin.version>3.13.0</maven-compiler-plugin.version>
		<maven-surefire-plugin.version>3.5.4</maven-surefire-plugin.version>
		<maven-source-plugin.version>3.3.1</maven-source-plugin.version>
		<maven-javadoc-plugin.version>3.6.3</maven-javadoc-plugin.version>
		<jacoco-maven-plugin.version>0.8.14</jacoco-maven-plugin.version>
		<!-- Per-module LINE coverage floor enforced by jacoco:check under -Pquality.
		     Wired but set to 0 for now; ratchet up per module as tests are added. -->
		<jacoco.line.min>0.0</jacoco.line.min>
		<maven-jar-plugin.version>3.4.1</maven-jar-plugin.version>
		<maven-exec-plugin.version>3.1.0</maven-exec-plugin.version>
		<maven-enforcer-plugin.version>3.5.0</maven-enforcer-plugin.version>
		<spotbugs-maven-plugin.version>4.9.8.3</spotbugs-maven-plugin.version>
		<spotbugs.version>4.9.8</spotbugs.version>
		<maven-pmd-plugin.version>3.28.0</maven-pmd-plugin.version>
		<!-- Empty-jar guard (mirrors core): dormant by default, opt-in per module. -->
		<enforce.jar.size.skip>true</enforce.jar.size.skip>
	</properties>

