<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>com.garganttua</groupId>
        <artifactId>garganttua-events-starters</artifactId>
        <version>3.0.0-ALPHA06</version>
    </parent>

    <artifactId>garganttua-events-starter-api</artifactId>
    <packaging>pom</packaging>
    <description>Batteries-included garganttua-events starter for the garganttua-api connector:
        events engine (DSL + core) + api connector (observe garganttua-api business events) +
        observability connector (full firehose) + JVM reflection stack + bootstrap. Both
        connectors self-register on the global observability firehose, so an api-events app
        receives events with zero wiring. Depend on this single artifact to build/run an events
        app that ingests api business events.</description>

    <dependencies>
        <dependency>
            <groupId>com.garganttua</groupId>
            <artifactId>garganttua-events-core</artifactId>
            <version>${project.version}</version>
        </dependency>
        <dependency>
            <groupId>com.garganttua</groupId>
            <artifactId>garganttua-events-connector-api</artifactId>
            <version>${project.version}</version>
        </dependency>
        <!-- connector-api no longer depends on connector-observability; bundle it explicitly so an
             api-events app still gets the full observability firehose connector. -->
        <dependency>
            <groupId>com.garganttua</groupId>
            <artifactId>garganttua-events-connector-observability</artifactId>
            <version>${project.version}</version>
        </dependency>
        <!-- Built-in @Expression route-stage functions (log / produce / protocol_* / filter_*).
             On the classpath so EventExpressions resolves without -Dgarganttua.packages. -->
        <dependency>
            <groupId>com.garganttua</groupId>
            <artifactId>garganttua-events-expressions</artifactId>
            <version>${project.version}</version>
        </dependency>
        <!-- Bootstrap wires reflection + injection + expression + the events module. -->
        <dependency>
            <groupId>com.garganttua.core</groupId>
            <artifactId>garganttua-bootstrap</artifactId>
            <version>${garganttua.core.version}</version>
        </dependency>
        <!-- JVM reflection stack (runtime-reflection + reflections). -->
        <dependency>
            <groupId>com.garganttua.core</groupId>
            <artifactId>garganttua-starter-runtime</artifactId>
            <version>${garganttua.core.version}</version>
            <type>pom</type>
        </dependency>
    </dependencies>
</project>
