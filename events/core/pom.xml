<project xmlns="http://maven.apache.org/POM/4.0.0"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>

	<parent>
		<groupId>com.garganttua</groupId>
		<artifactId>garganttua-events</artifactId>
		<version>3.0.0-ALPHA04</version>
	</parent>

	<artifactId>garganttua-events-core</artifactId>
	<packaging>jar</packaging>

	<dependencies>
		<dependency>
			<groupId>com.garganttua</groupId>
			<artifactId>garganttua-events-api</artifactId>
		</dependency>
		<dependency>
			<groupId>com.garganttua.core</groupId>
			<artifactId>garganttua-commons</artifactId>
		</dependency>
		<dependency>
			<groupId>com.garganttua.core</groupId>
			<artifactId>garganttua-dsl</artifactId>
		</dependency>
		<dependency>
			<groupId>com.garganttua.core</groupId>
			<artifactId>garganttua-workflow</artifactId>
		</dependency>
		<dependency>
			<groupId>com.garganttua.core</groupId>
			<artifactId>garganttua-expression</artifactId>
		</dependency>
		<dependency>
			<groupId>com.garganttua.core</groupId>
			<artifactId>garganttua-injection</artifactId>
		</dependency>
		<dependency>
			<groupId>com.garganttua.core</groupId>
			<artifactId>garganttua-lifecycle</artifactId>
		</dependency>
		<dependency>
			<groupId>com.garganttua.core</groupId>
			<artifactId>garganttua-script</artifactId>
		</dependency>
		<dependency>
			<groupId>com.fasterxml.jackson.core</groupId>
			<artifactId>jackson-databind</artifactId>
		</dependency>
		<dependency>
			<groupId>org.projectlombok</groupId>
			<artifactId>lombok</artifactId>
		</dependency>
		<dependency>
			<groupId>org.slf4j</groupId>
			<artifactId>slf4j-api</artifactId>
		</dependency>
		<dependency>
			<groupId>org.junit.jupiter</groupId>
			<artifactId>junit-jupiter-api</artifactId>
		</dependency>
		<dependency>
			<groupId>org.junit.jupiter</groupId>
			<artifactId>junit-jupiter-engine</artifactId>
			<version>${junit.version}</version>
			<scope>test</scope>
		</dependency>
		<!-- Test-only JVM reflection provider so IClass.getReflection() resolves during the
		     EventsBuilder static-init (its DEPENDENCIES set calls IClass.getClass). -->
		<dependency>
			<groupId>com.garganttua.core</groupId>
			<artifactId>garganttua-runtime-reflection</artifactId>
			<version>${garganttua.core.version}</version>
			<scope>test</scope>
		</dependency>
		<!-- @ConfigurableBuilder("events") population test: drives the real
		     BootstrapConfigurationContributor against an EventsBuilder. -->
		<dependency>
			<groupId>com.garganttua.core</groupId>
			<artifactId>garganttua-configuration</artifactId>
			<scope>test</scope>
		</dependency>
		<!-- E2E route test: the events @Expression functions (produce/set_header/log) are
		     discovered by the expression context at runtime; the test needs them on its classpath
		     to drive a real route through the engine. Test scope only (no production cycle:
		     events-expressions depends on events-api, not events-core). -->
		<dependency>
			<groupId>com.garganttua</groupId>
			<artifactId>garganttua-events-expressions</artifactId>
			<version>${project.version}</version>
			<scope>test</scope>
		</dependency>
		<!-- JVM annotation scanner for the e2e route test: lets the expression context discover the
		     events @Expression functions by package scan (no AOT index needed at test time). -->
		<dependency>
			<groupId>com.garganttua.core</groupId>
			<artifactId>garganttua-reflections</artifactId>
			<version>${garganttua.core.version}</version>
			<scope>test</scope>
		</dependency>
	</dependencies>

	<!-- Supplies the checkstyle SuppressionFilter location the shared
	     config/checkstyle/checkstyle.xml expects via ${checkstyle.suppressions.file}.
	     The parent (garganttua-events) quality profile sets configLocation but not
	     suppressionsLocation, so the standalone `checkstyle:check` cannot resolve the
	     property; this additive override fixes that without changing any rules. -->
	<profiles>
		<profile>
			<id>quality</id>
			<build>
				<plugins>
					<plugin>
						<groupId>org.apache.maven.plugins</groupId>
						<artifactId>maven-checkstyle-plugin</artifactId>
						<configuration>
							<suppressionsLocation>${maven.multiModuleProjectDirectory}/config/checkstyle/suppressions.xml</suppressionsLocation>
						</configuration>
					</plugin>
				</plugins>
			</build>
		</profile>
	</profiles>

</project>
